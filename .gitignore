node_modules/
.env
.env.local
data/*
# Allow the example pentest-history schema reference — it documents the
# /trust dashboard's input shape without containing any real engagement data.
!data/pentest-history.example.json
# Allow the substrate-shipped ARC test fixtures — they are doctrine-
# bound test corpus per COGOS_PROCESS_DETERMINISM §10.2 / §10.7
# (NOT real ARC corpus tasks · operator corpora live elsewhere
# via COGOS_ARC_CORPUS_ROOTS per PD-W12).
!data/arc-tasks/
!data/arc-tasks/demo-*.json
*.log
coverage/
.DS_Store
.idea/
.vscode/
.claude/

# cosign signing keys — private key NEVER committed; pubkey published via env
cosign.key
cosign.pub
cosign.password
# Backups produced by scripts/cosign-regenerate.sh are encrypted with the
# old password but still sensitive — never commit.
cosign.key.bak.*
