# cogos-api — local config example. Copy to .env and edit.

PORT=4444

# Ollama backend (or any compatible chat-completions endpoint, e.g. vLLM)
OLLAMA_URL=http://localhost:11434

# Default model when caller doesn't specify (or specifies a CogOS tier alias)
DEFAULT_MODEL=qwen2.5:3b-instruct

# Admin key for issuing customer API keys (sk-cogos-...). Hex-32 recommended.
# Treat this like a database root password.
ADMIN_KEY=replace-with-strong-random

# Per-call execution timeout (ms)
INFERENCE_TIMEOUT_MS=60000

LOG_LEVEL=info

# ---- Stripe self-serve signup ----
# Get these from https://dashboard.stripe.com/apikeys (test mode first)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# (set this AFTER creating the webhook endpoint pointing at /stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Price ID for the Operator Starter ($25/mo subscription)
# Create at https://dashboard.stripe.com/products → New product → Recurring
STRIPE_PRICE_ID=price_replace_me
