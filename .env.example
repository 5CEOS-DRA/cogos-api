# cogos-api — local config example. Copy to .env and edit.

PORT=4444

# ---- Upstream inference engine ----
# UPSTREAM_PROVIDER selects which protocol to speak upstream:
#   ollama  — calls <UPSTREAM_URL>/api/chat (Ollama 0.5+ native shape)
#   openai  — calls <UPSTREAM_URL>/chat/completions with Bearer <UPSTREAM_API_KEY>
#             NOTE: per the vendor-exclusion architecture, UPSTREAM_URL for
#             provider=openai is constrained to operator-owned endpoints
#             (e.g. a sibling Ollama/vLLM container on the same managed env),
#             NOT third-party hosted LLM APIs.
UPSTREAM_PROVIDER=ollama
UPSTREAM_URL=http://localhost:11434
UPSTREAM_API_KEY=

# Override model tier resolution (defaults shown). Optional.
UPSTREAM_MODEL_TIER_A=qwen2.5:7b-instruct
UPSTREAM_MODEL_TIER_B=qwen2.5:3b-instruct

# Legacy alias for UPSTREAM_URL — read as fallback when UPSTREAM_URL unset.
# OLLAMA_URL=http://localhost:11434

# Default model when caller doesn't specify (or specifies a CogOS tier alias)
DEFAULT_MODEL=qwen2.5:3b-instruct

# Admin key for issuing customer API keys (sk-cogos-...). Hex-32 recommended.
# Treat this like a database root password.
ADMIN_KEY=replace-with-strong-random

# Per-call execution timeout (ms)
INFERENCE_TIMEOUT_MS=60000

LOG_LEVEL=info

# ---- Substrate-automatic frontier escalation (CL-NEVER-1 rev 2026-06-06) ----
# When the sovereign tier (Ollama) cannot resolve a call, the substrate
# automatically escalates to a frontier provider and writes
# was_escalated=TRUE + frontier_provider + escalation_reason to the audit
# row. Set FRONTIER_ESCALATION_ENABLED=false to disable.
FRONTIER_ESCALATION_ENABLED=true
FRONTIER_PROVIDER=gemini
FRONTIER_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
FRONTIER_API_KEY=replace-with-google-ai-studio-key
FRONTIER_MODEL=gemini-2.5-flash
FRONTIER_TIMEOUT_MS=30000

# Per-1M-token cost estimates for /admin/escalation-metrics. Operator-tunable.
# Defaults reflect Gemini 2.5 Flash paid-tier pricing in USD.
FRONTIER_COST_INPUT_USD_PER_1M=0.075
FRONTIER_COST_OUTPUT_USD_PER_1M=0.30
FRONTIER_FREE_TIER_RPD=1500

# Hard daily-spend ceiling on substrate-automatic frontier escalation.
# Before each escalation, the cap is checked against running daily spend
# computed from the audit log. When breached, sovereign errors surface
# unchanged — no silent routing AND no silent overage. 0 disables.
FRONTIER_DAILY_BUDGET_USD_CAP=50.00

# Phase 1 learning log location · captures (prompt → frontier response) pairs
# for downstream fine-tuning / cache / tier-promotion. Operator-only access
# via /admin/escalation-learning. Default lives under cogos-api/data/.
# ESCALATION_LEARNING_FILE=/var/lib/cogos/escalation-learning.jsonl

# ---- Stripe self-serve signup ----
# Get these from https://dashboard.stripe.com/apikeys (test mode first)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# (set this AFTER creating the webhook endpoint pointing at /stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Price ID for the Operator Starter ($25/mo subscription)
# Create at https://dashboard.stripe.com/products → New product → Recurring
STRIPE_PRICE_ID=price_replace_me
